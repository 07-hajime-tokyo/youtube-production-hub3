NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Local development only: set to 1 to skip Supabase login.
LOCAL_AUTH_BYPASS=0

# Comma-separated team allowlist for web login.
ALLOWED_EMAILS=you@example.com,teammate@example.com

# Google Drive sync.
GOOGLE_DRIVE_FOLDER_ID=
# Optional: limit Drive sync to selected channel spreadsheets.
GOOGLE_DRIVE_SPREADSHEET_IDS=
# Use either GOOGLE_APPLICATION_CREDENTIALS or GOOGLE_SERVICE_ACCOUNT_JSON.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Notion task and handoff link sync.
NOTION_TOKEN=
NOTION_SCHEDULE_DATABASE_ID=
NOTION_LINKS_DATABASE_ID=

# Local storage / export settings.
OBSIDIAN_VAULT_DIR=/Users/ha_m/Desktop/Obsidian Vault
GITHUB_TRANSCRIPTS_DIR=transcripts
# Set to 1 only when you also want Markdown files in Obsidian/GitHub.
TRANSCRIPT_MARKDOWN_EXPORT=0
# local: bundled faster-whisper / groq: Groq hosted Whisper API.
TRANSCRIBE_PROVIDER=local
TRANSCRIBE_MODEL=small
GROQ_API_KEY=
GROQ_TRANSCRIBE_MODEL=whisper-large-v3
WORKER_POLL_INTERVAL_MS=5000

# Optional: trigger GitHub Actions immediately when a transcript job is enqueued.
GITHUB_ACTIONS_TOKEN=
GITHUB_ACTIONS_OWNER=07-hajime-tokyo
GITHUB_ACTIONS_REPO=youtube-production-hub3
GITHUB_TRANSCRIBE_WORKFLOW=transcribe-worker.yml
GITHUB_ACTIONS_REF=main

YTDLP_BIN=/opt/homebrew/bin/yt-dlp
FFMPEG_BIN=ffmpeg
# Local worker only. Use Chrome's logged-in YouTube cookies for yt-dlp.
YTDLP_COOKIES_FROM_BROWSER=chrome
# Alternative for server workers. Never commit the cookies file.
# YTDLP_COOKIES_PATH=/absolute/path/to/youtube-cookies.txt
PYTHON_BIN=/usr/bin/python3
